<mxfile host="app.diagrams.net">
  <diagram name="Casos de Uso">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>

        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- SISTEMA (GRANDE Y CENTRADO) -->
        <mxCell id="2"
                value="Sistema de Entrenamiento Cognitivo Adaptativo"
                style="rounded=0;strokeWidth=2;fillColor=none;"
                vertex="1"
                parent="1">
          <mxGeometry x="200" y="80" width="800" height="600" as="geometry"/>
        </mxCell>

        <!-- ACTORES -->
        <mxCell id="3"
                value="Usuario final"
                style="shape=umlActor"
                vertex="1"
                parent="1">
          <mxGeometry x="40" y="200" width="60" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="4"
                value="Administrador"
                style="shape=umlActor"
                vertex="1"
                parent="1">
          <mxGeometry x="40" y="420" width="60" height="120" as="geometry"/>
        </mxCell>

        <!-- CASOS DE USO (MEJOR DISTRIBUIDOS) -->
        <mxCell id="5" value="Iniciar sesión"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="80" y="80" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="6" value="Resolver ejercicio"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="300" y="80" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="7" value="Finalizar sesión"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="520" y="80" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="8" value="Consultar progreso"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="740" y="80" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="9" value="Administrar usuarios"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="300" y="220" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="10" value="Configurar sistema"
                style="ellipse;whiteSpace=wrap;html=1"
                vertex="1" parent="2">
          <mxGeometry x="520" y="220" width="170" height="60" as="geometry"/>
        </mxCell>

        <!-- CONEXIONES USUARIO -->
        <mxCell id="11" edge="1" parent="1" source="3" target="5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="12" edge="1" parent="1" source="3" target="6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="13" edge="1" parent="1" source="3" target="7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="14" edge="1" parent="1" source="3" target="8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CONEXIONES ADMIN -->
        <mxCell id="15" edge="1" parent="1" source="4" target="9">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="16" edge="1" parent="1" source="4" target="10">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>